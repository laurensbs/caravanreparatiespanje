# ─── Database ───
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/repair_admin?sslmode=require

# ─── Auth ───
AUTH_SECRET=generate-with-npx-auth-secret
AUTH_URL=http://localhost:3000

# ─── Seed Admin ───
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# ─── Holded ───
HOLDED_API_KEY=your-holded-api-key
ADMIN_NAME=Admin User

# ─── App ───
NEXT_PUBLIC_APP_NAME=Repair Admin
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Microsoft OneDrive (Graph API) ───
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
ONEDRIVE_USER_EMAIL=user@your-org.onmicrosoft.com
ONEDRIVE_ROOT_FOLDER=Reparaties
